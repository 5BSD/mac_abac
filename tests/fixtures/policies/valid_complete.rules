# Complete valid policy demonstrating all features

# Basic allow/deny rules
allow exec type=trusted -> *
deny exec * -> type=untrusted

# Multiple operations
allow read,write,open,stat domain=app -> domain=app

# Context constraints
deny debug * -> * ctx:sandboxed=true
allow signal type=supervisor ctx:uid=0 -> type=worker

# Transition rules
transition exec * -> type=setuid_bin => type=elevated

# Wildcards
allow lookup * -> *
allow stat * -> *

# Negation patterns
deny exec !type=trusted -> type=sensitive
