# Multi-tenant isolation policy
# Each tenant can only access their own data

# Tenant A isolation
allow read,write,open tenant=a -> tenant=a
deny read,write,open tenant=a -> tenant=b
deny read,write,open tenant=a -> tenant=c

# Tenant B isolation
allow read,write,open tenant=b -> tenant=b
deny read,write,open tenant=b -> tenant=a
deny read,write,open tenant=b -> tenant=c

# Tenant C isolation
allow read,write,open tenant=c -> tenant=c
deny read,write,open tenant=c -> tenant=a
deny read,write,open tenant=c -> tenant=b

# System processes can access everything
allow all type=system -> *
