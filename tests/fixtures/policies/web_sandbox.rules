# Web application sandbox policy
# Processes with domain=web can only access files with domain=web

# Allow web processes to access web files
allow read,write,open domain=web -> domain=web

# Allow web processes to execute trusted binaries
allow exec domain=web -> type=trusted

# Deny web processes from accessing system files
deny read,write domain=web -> domain=system

# Allow all for trusted processes
allow all type=trusted -> *
