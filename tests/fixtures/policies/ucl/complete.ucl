# Complete UCL policy testing all features
# Tests: mode, operations, patterns, context, transitions

mode = "enforcing";

rules = [
    {
        # Basic deny rule with single operation
        id = 1;
        action = "deny";
        operations = ["exec"];
        subject = "*";
        object = { type = "malware"; };
    },

    {
        # Multiple operations as array
        id = 2;
        action = "allow";
        operations = ["read", "write", "mmap", "stat"];
        subject = { domain = "app"; };
        object = { domain = "app"; };
    },

    {
        # All operations with wildcard
        id = 3;
        action = "allow";
        operations = ["all"];
        subject = { type = "admin"; };
        object = "*";
    },

    {
        # Subject context constraint (jail)
        id = 4;
        action = "deny";
        operations = ["exec"];
        subject = "*";
        object = { type = "hostonly"; };
        context = { jail = "any"; };
    },

    {
        # Subject context constraint (uid)
        id = 5;
        action = "allow";
        operations = ["exec"];
        subject = "*";
        object = { type = "privileged"; };
        context = { uid = 0; };
    },

    {
        # Subject context constraint (sandboxed)
        id = 6;
        action = "deny";
        operations = ["exec", "mmap"];
        subject = "*";
        object = "*";
        context = { sandboxed = true; };
    },

    {
        # Object context constraint (for process ops)
        id = 7;
        action = "deny";
        operations = ["debug"];
        subject = "*";
        object = "*";
        obj_context = { sandboxed = true; };
    },

    {
        # Transition rule with newlabel
        id = 10;
        action = "transition";
        operations = ["exec"];
        subject = { type = "user"; };
        object = { type = "setuid"; name = "su"; };
        newlabel = "type=admin,domain=system";
    },

    {
        # Complex multi-field patterns
        id = 11;
        action = "allow";
        operations = ["read", "write"];
        subject = { type = "app"; domain = "web"; tier = "frontend"; };
        object = { type = "data"; domain = "web"; sensitivity = "public"; };
    },

    {
        # Pattern with negation
        id = 12;
        action = "deny";
        operations = ["exec"];
        subject = "*";
        object = { type = "dangerous"; negate = true; };
    },

    {
        # Process operations
        id = 20;
        action = "allow";
        operations = ["debug", "signal", "sched"];
        subject = { type = "supervisor"; };
        object = { type = "worker"; };
    },

    {
        # Single operation as string (not array)
        id = 21;
        action = "allow";
        operations = "read";
        subject = "*";
        object = { type = "public"; };
    },

    {
        # Catch-all allow
        id = 100;
        action = "allow";
        operations = ["all"];
        subject = "*";
        object = "*";
    }
];
